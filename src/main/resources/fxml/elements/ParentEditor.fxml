<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.editor.ParentEditorController"
      spacing="14.0"
      styleClass="chapterEditor-container">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16" />
    </padding>

    <HBox alignment="CENTER_LEFT">
        <Label fx:id="typeLabel" text="Element" styleClass="editor-type-badge" />
    </HBox>

    <VBox spacing="6.0">
        <Label fx:id="titleLabel" text="Title" styleClass="section-label" />
        <TextField fx:id="titleField" promptText="Title" styleClass="title-field" />
    </VBox>

    <VBox fx:id="pointsBox" spacing="6.0" visible="false" managed="false">
        <Label fx:id="pointsLabel" text="Points" styleClass="section-label" />
        <TextField fx:id="pointsField" promptText="Points" styleClass="dark-input"/>
    </VBox>

    <VBox fx:id="difficultyBoxContainer" spacing="6.0" visible="false" managed="false">
        <Label fx:id="difficultyLabel" text="Difficulty" styleClass="section-label" />
        <ComboBox fx:id="difficultyBox" maxWidth="1.7976931348623157E308" styleClass="dark-input"/>
    </VBox>

    <VBox fx:id="labelsBox" spacing="6.0" visible="false" managed="false">
        <Label fx:id="labelsLabel" text="Labels" styleClass="section-label" />
        <TextField fx:id="labelsField" promptText="Practice, Exam" styleClass="dark-input" />
    </VBox>

    <VBox fx:id="questionBox" spacing="6.0" visible="false" managed="false" VBox.vgrow="ALWAYS">
        <Label fx:id="questionLabel" text="Question" styleClass="section-label" />
        <TextArea fx:id="questionField" promptText="Question" prefRowCount="6" wrapText="true" maxHeight="1.7976931348623157E308" styleClass="dark-input" VBox.vgrow="ALWAYS" />
    </VBox>

    <VBox fx:id="solutionBox" spacing="6.0" visible="false" managed="false" VBox.vgrow="ALWAYS">
        <Label fx:id="solutionLabel" text="Solution" styleClass="section-label" />
        <TextArea fx:id="solutionField" promptText="Solution" prefRowCount="6" wrapText="true" maxHeight="1.7976931348623157E308" styleClass="dark-input" VBox.vgrow="ALWAYS" />
    </VBox>

    <VBox spacing="8.0">
        <Label fx:id="childSectionLabel" text="Unterelemente" styleClass="section-label" />
        <VBox fx:id="childList" spacing="6.0" styleClass="subtasks-box">
            <padding>
                <Insets top="12" right="12" bottom="12" left="12" />
            </padding>
        </VBox>
        <Button fx:id="addChild" text="Create" styleClass="editor-secondary-button" onAction="#toggleAddNewChild"/>
    </VBox>

    <Region VBox.vgrow="ALWAYS" />

    <HBox spacing="10.0" alignment="CENTER_RIGHT" styleClass="action-bar">
        <Label fx:id="actionFeedbackLabel" text="" styleClass="action-feedback" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" visible="false" managed="false" />
        <Button fx:id="deleteButton" text="Delete" styleClass="editor-danger-button" />
        <Button fx:id="saveButton" text="Save" styleClass="editor-primary-button" onAction="#handleSave" />
        <Button fx:id="createButton" text="Create" styleClass="editor-primary-button" onAction="#handleCreate" visible="false" managed="false" />
    </HBox>
</VBox>
