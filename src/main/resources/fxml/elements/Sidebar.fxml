<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.SidebarController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            vbarPolicy="AS_NEEDED"
            minWidth="220.0"
            prefWidth="260.0"
            styleClass="sidebar-scroll">
    <content>
        <VBox styleClass="sidebar-container">
            <HBox alignment="CENTER_LEFT" spacing="8" styleClass="sidebar-heading-row">
                <Label fx:id="headingLabel" text="Outline" styleClass="sidebar-heading" HBox.hgrow="ALWAYS" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="addChapterButton"
                        text="New chapter"
                        onAction="#handleCreateChapter"
                        styleClass="sidebar-add-button" />
            </HBox>
            <VBox fx:id="chapterBox" spacing="8" />
        </VBox>
    </content>
</ScrollPane>
