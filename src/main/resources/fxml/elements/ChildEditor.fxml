<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.editor.ChildEditorController"
      spacing="14.0"
      styleClass="chapterEditor-container">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16" />
    </padding>

    <VBox spacing="6.0">
        <Label fx:id="typeLabel" text="Variant" styleClass="editor-type-badge" />
        <Label fx:id="headerLabel" text="Variant" styleClass="header-label" />
    </VBox>

    <VBox spacing="6.0">
        <Label fx:id="titleLabel" text="Title" styleClass="section-label" />
        <TextField fx:id="titleField" promptText="Title" styleClass="dark-input" />
    </VBox>

    <VBox spacing="6.0">
        <Label fx:id="questionLabel" text="Question" styleClass="section-label" />
        <TextArea fx:id="questionField" promptText="Question" prefRowCount="4" styleClass="dark-input" />
    </VBox>

    <VBox spacing="6.0">
        <Label fx:id="solutionLabel" text="Solution" styleClass="section-label" />
        <TextArea fx:id="solutionField" promptText="Solution" prefRowCount="4" styleClass="dark-input"/>
    </VBox>

    <Region VBox.vgrow="ALWAYS" />

    <HBox spacing="10.0" alignment="CENTER_RIGHT" styleClass="action-bar">
        <Label fx:id="actionFeedbackLabel" text="" styleClass="action-feedback" maxWidth="1.7976931348623157E308" HBox.hgrow="ALWAYS" visible="false" managed="false" />
        <Button fx:id="deleteButton" text="Delete" styleClass="danger-button" />
        <Button fx:id="saveButton" text="Save" styleClass="primary-button" onAction="#handleSave" />
    </HBox>
</VBox>
