<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.exam.PdfLayoutDialogController"
            styleClass="root">
    <center>
        <VBox spacing="12.0" styleClass="generate-dialog-content">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>

            <CheckBox fx:id="coverPageCheckBox"/>

            <VBox fx:id="coverFieldsBox" spacing="10.0">
                <Label fx:id="coverTitleLabel" styleClass="section-label"/>
                <TextField fx:id="coverTitleField" styleClass="title-field"/>
                <Label fx:id="coverSubtitleLabel" styleClass="section-label"/>
                <TextField fx:id="coverSubtitleField" styleClass="title-field"/>
            </VBox>

            <Label fx:id="headerLabel" styleClass="section-label"/>
            <TextField fx:id="headerField" styleClass="title-field"/>

            <Label fx:id="footerLabel" styleClass="section-label"/>
            <TextField fx:id="footerField" styleClass="title-field"/>

            <CheckBox fx:id="pageNumbersCheckBox"/>
            <Label fx:id="helperLabel" styleClass="generate-dialog-status" wrapText="true"/>

            <HBox spacing="10.0" alignment="CENTER_RIGHT">
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="cancelButton" styleClass="editor-secondary-button" onAction="#handleCancel"/>
                <Button fx:id="saveButton" styleClass="editor-primary-button" onAction="#handleSave"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
